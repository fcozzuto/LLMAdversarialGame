{
  "agents": [
    {
      "max_tokens": 1200,
      "model": "gpt-5.4-nano",
      "name": "agent_a",
      "provider": "openai",
      "system_prompt": "You write deterministic Python for a grid-game agent.",
      "temperature": 0.2
    },
    {
      "max_tokens": 1200,
      "model": "gpt-5-nano",
      "name": "agent_b",
      "provider": "openai",
      "system_prompt": "You write deterministic Python for a grid-game agent.",
      "temperature": 0.2
    }
  ],
  "feedback": {
    "history_window": 1,
    "include_codes": true,
    "include_grid_state": true,
    "include_opponent_code": true,
    "include_paths": true,
    "include_runtime_events": true,
    "include_scores": true
  },
  "game": {
    "epochs": 10,
    "max_turns": 80,
    "move_timeout_seconds": 0.35,
    "tie_break": "split"
  },
  "judge": {
    "enabled": true,
    "max_tokens": 1800,
    "model": "gpt-5-nano",
    "provider": "openai",
    "temperature": 0.1,
    "timeout_seconds": 300
  },
  "map": {
    "height": 8,
    "obstacle_count": 2,
    "resample_each_epoch": true,
    "resource_count": 12,
    "width": 8
  },
  "metadata": {},
  "name": "cross_model_full_feedback",
  "observation": {
    "allow_diagonal": true,
    "allow_stay": true,
    "reveal_paths_each_turn": false,
    "reveal_scores_each_turn": true
  },
  "output_root": "runs",
  "seed": 202
}