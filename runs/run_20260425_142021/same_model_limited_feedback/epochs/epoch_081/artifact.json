  "codes": {
    "agent_a": "def choose_move(observation):\n    sx, sy = observation[\"self_position\"]\n    resources = observation.get(\"resources\", [])\n    if not resources:\n        return [0, 0]\n    best = min(resources, key=lambda item: abs(item[0] - sx) + abs(item[1] - sy))\n    dx = 0 if best[0] == sx else (1 if best[0] > sx else -1)\n    dy = 0 if best[1] == sy else (1 if best[1] > sy else -1)\n    return [dx, dy]",
    "agent_b": "def choose_move(observation):\n    sx, sy = observation[\"self_position\"]\n    resources = observation.get(\"resources\", [])\n    if not resources:\n        return [0, 0]\n    best = min(resources, key=lambda item: abs(item[0] - sx) + abs(item[1] - sy))\n    dx = 0 if best[0] == sx else (1 if best[0] > sx else -1)\n    dy = 0 if best[1] == sy else (1 if best[1] > sy else -1)\n    return [dx, dy]"
