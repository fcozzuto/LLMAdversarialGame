{
  "defaults": {
    "seed": 651,
    "output_root": "runs/curriculum_suite/holdout_evaluation",
    "agents": [
      {
        "name": "agent_a",
        "provider": "openai",
        "model": "gpt-5.4-nano",
        "temperature": 0.2,
        "max_tokens": 1200
      },
      {
        "name": "agent_b",
        "provider": "builtin",
        "model": "nearest_resource",
        "temperature": 0.0,
        "max_tokens": 1,
        "regenerate_each_epoch": false
      }
    ],
    "feedback": {
      "history_window": 1,
      "code_history_window": 1,
      "include_scores": true,
      "include_paths": true,
      "include_codes": true,
      "include_opponent_code": true,
      "include_grid_state": true,
      "include_runtime_events": true
    },
    "observation": {
      "reveal_scores_each_turn": true,
      "reveal_paths_each_turn": false,
      "allow_stay": true,
      "allow_diagonal": true
    },
    "map": {
      "width": 8,
      "height": 8,
      "resource_count": 12,
      "obstacle_count": 2,
      "resample_each_epoch": true
    },
    "game": {
      "epochs": 100,
      "max_turns": 80,
      "move_timeout_seconds": 0.35,
      "tie_break": "split"
    },
    "judge": {
      "enabled": true,
      "provider": "openai",
      "model": "gpt-4.1-mini",
      "temperature": 0.1,
      "max_tokens": 2200,
      "timeout_seconds": 300
    },
    "generation": {
      "pre_execution_validation": true,
      "repair_invalid_submissions": true
    },
    "curriculum": {
      "enabled": true,
      "focal_agent": "agent_a",
      "opponent_agent": "agent_b",
      "mode": "holdout_evaluation",
      "rotation_policy": "cyclic",
      "rotation_stride": 1,
      "archive": {
        "enabled": true,
        "reintroduce_every": 5,
        "min_score_margin": 1.0,
        "max_size": 8
      },
      "pressure": {
        "enabled": true,
        "loss_streak_trigger": 1,
        "score_margin_trigger": 1.0,
        "require_substantial_change": true,
        "custom_instruction": "Your last approach failed. Propose a substantially different algorithmic strategy."
      },
      "selection": {
        "mode": "score_or_diversity",
        "novelty_metric": "behavioral_distance",
        "novelty_threshold": 0.2,
        "score_tolerance": 0.75
      },
      "opponent_pool": [
        {
          "library_key": "nearest_resource"
        },
        {
          "library_key": "opponent_shadow"
        },
        {
          "library_key": "sweep_rows"
        }
      ],
      "evaluation": {
        "enabled": true,
        "games_per_opponent": 3,
        "holdout_opponents": [
          {
            "library_key": "center_rush"
          },
          {
            "library_key": "corner_guard"
          },
          {
            "library_key": "resource_denier"
          }
        ]
      }
    },
    "metadata": {
      "suite_family": "curriculum_suite",
      "suite_type": "holdout_evaluation"
    }
  },
  "conditions": [
    {
      "name": "rotating_curriculum_with_holdout_panel",
      "seed": 651,
      "metadata": {
        "suite_family": "curriculum_suite",
        "suite_type": "holdout_evaluation",
        "holdout_enabled": true
      }
    }
  ]
