{
  "defaults": {
    "seed": 601,
    "output_root": "runs/curriculum_suite/fixed_predator",
    "agents": [
      {
        "name": "agent_a",
        "provider": "openai",
        "model": "gpt-5.4-nano",
        "temperature": 0.2,
        "max_tokens": 1200
      },
      {
        "name": "agent_b",
        "provider": "builtin",
        "model": "opponent_shadow",
        "temperature": 0.0,
        "max_tokens": 1,
        "regenerate_each_epoch": false
      }
    ],
    "feedback": {
      "history_window": 1,
      "code_history_window": 1,
      "include_scores": true,
      "include_paths": true,
      "include_codes": true,
      "include_opponent_code": true,
      "include_grid_state": true,
      "include_runtime_events": true
    },
    "observation": {
      "reveal_scores_each_turn": true,
      "reveal_paths_each_turn": false,
      "allow_stay": true,
      "allow_diagonal": true
    },
    "map": {
      "width": 8,
      "height": 8,
      "resource_count": 12,
      "obstacle_count": 2,
      "resample_each_epoch": true
    },
    "game": {
      "epochs": 100,
      "max_turns": 80,
      "move_timeout_seconds": 0.35,
      "tie_break": "split"
    },
    "judge": {
      "enabled": true,
      "provider": "openai",
      "model": "gpt-4.1-mini",
      "temperature": 0.1,
      "max_tokens": 2200,
      "timeout_seconds": 300
    },
    "generation": {
      "pre_execution_validation": true,
      "repair_invalid_submissions": true
    },
    "curriculum": {
      "enabled": true,
      "focal_agent": "agent_a",
      "opponent_agent": "agent_b",
      "mode": "fixed_predator",
      "rotation_policy": "cyclic",
      "rotation_stride": 1,
      "archive": {
        "enabled": false
      },
      "pressure": {
        "enabled": false
      },
      "selection": {
        "mode": "score_or_diversity",
        "novelty_metric": "behavioral_distance",
        "novelty_threshold": 0.2,
        "score_tolerance": 0.5,
        "elite_archive_enabled": true,
        "elite_archive_max_size": 8,
        "elite_distance_threshold": 0.18,
        "elite_score_tolerance": 0.5
      }
    },
    "metadata": {
      "suite_family": "curriculum_suite",
      "suite_type": "fixed_predator"
    }
  },
  "conditions": [
    {
      "name": "fixed_predator_opponent_shadow",
      "seed": 601,
      "curriculum": {
        "opponent_pool": [
          {
            "library_key": "opponent_shadow"
          }
        ]
      },
      "metadata": {
        "suite_family": "curriculum_suite",
        "suite_type": "fixed_predator",
        "predator_label": "opponent_shadow"
      }
    },
    {
      "name": "fixed_predator_resource_denier",
      "seed": 602,
      "curriculum": {
        "opponent_pool": [
          {
            "library_key": "resource_denier"
          }
        ]
      },
      "metadata": {
        "suite_family": "curriculum_suite",
        "suite_type": "fixed_predator",
        "predator_label": "resource_denier"
      }
    }
  ]
}
