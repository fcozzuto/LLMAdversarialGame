{
  "defaults": {
    "seed": 19,
    "output_root": "runs",
    "agents": [
      {
        "name": "agent_a",
        "provider": "openai",
        "model": "gpt-5-nano",
        "temperature": 0.2,
        "max_tokens": 1000
      },
      {
        "name": "agent_b",
        "provider": "groq",
        "model": "openai/gpt-oss-120b",
        "temperature": 0.2,
        "max_tokens": 1000
      }
    ],
    "feedback": {
      "history_window": 1,
      "include_scores": true,
      "include_paths": true,
      "include_codes": true,
      "include_opponent_code": true,
      "include_grid_state": true,
      "include_runtime_events": true
    },
    "observation": {
      "reveal_scores_each_turn": true,
      "reveal_paths_each_turn": false,
      "allow_stay": true,
      "allow_diagonal": true
    },
    "map": {
      "width": 6,
      "height": 6,
      "resource_count": 8,
      "obstacle_count": 1,
      "resample_each_epoch": true
    },
    "game": {
      "epochs": 1,
      "max_turns": 40,
      "move_timeout_seconds": 0.35,
      "tie_break": "split"
    },
    "judge": {
      "enabled": true,
      "provider": "openai",
      "model": "gpt-5-nano",
      "temperature": 0.1,
      "max_tokens": 1200
    }
  },
  "conditions": [
    {
      "name": "live_cross_model_smoke",
      "seed": 1901
    }
  ]
}
