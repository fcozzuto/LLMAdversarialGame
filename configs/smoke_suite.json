{
  "defaults": {
    "seed": 7,
    "output_root": "runs",
    "agents": [
      {
        "name": "agent_a",
        "provider": "builtin",
        "model": "nearest_resource"
      },
      {
        "name": "agent_b",
        "provider": "builtin",
        "model": "opponent_shadow"
      }
    ],
    "feedback": {
      "history_window": 1,
      "include_scores": true,
      "include_paths": true,
      "include_codes": true,
      "include_opponent_code": true,
      "include_grid_state": true,
      "include_runtime_events": true
