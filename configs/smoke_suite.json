    "observation": {
      "reveal_scores_each_turn": true,
      "reveal_paths_each_turn": false,
      "allow_stay": true,
      "allow_diagonal": true
    },
    "map": {
      "width": 6,
      "height": 6,
      "resource_count": 8,
      "obstacle_count": 1,
      "resample_each_epoch": true
    },
    "game": {
      "epochs": 2,
      "max_turns": 40,
      "move_timeout_seconds": 0.2,
      "tie_break": "split"
    },
    "judge": {
      "enabled": false,
      "provider": "openai",
      "model": "gpt-5-nano",
      "temperature": 0.1,
      "max_tokens": 1200
    }
  },
  "conditions": [
    {
      "name": "builtin_smoke_a_vs_b",
      "seed": 77
    }
  ]
